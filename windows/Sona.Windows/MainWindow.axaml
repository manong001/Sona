<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="using:Sona.Windows.Models"
        x:Class="Sona.Windows.MainWindow"
        Width="1280" Height="800" MinWidth="900" MinHeight="620"
        Title="Sona">
  <Grid>
    <Grid x:Name="Shell" RowDefinitions="*,92" IsVisible="False">
      <Grid Grid.Row="0" ColumnDefinitions="246,8,*,8,300" Margin="8,8,8,0">
        <Border Grid.Column="0" Background="#121212" CornerRadius="10">
          <Grid RowDefinitions="64,Auto,1,Auto,*,64">
            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" Margin="18,0" VerticalAlignment="Center">
              <Border Width="32" Height="32" CornerRadius="16" Background="#1ED760">
                <TextBlock Text="♪" Foreground="#07150B" FontSize="21" FontWeight="Bold"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Border>
              <TextBlock Text="Sona" FontSize="22" FontWeight="Bold" VerticalAlignment="Center" />
            </StackPanel>

            <StackPanel Grid.Row="1" Margin="0,4,0,10">
              <Button Classes="nav" Content="⌂   首页" Click="Home_Click" />
              <Button Classes="nav" Content="✦   发现" Click="Discovery_Click" />
              <Button Classes="nav" Content="⌕   搜索" Click="SearchNav_Click" />
              <Button Classes="nav" Content="▤   音乐库" Click="Library_Click" />
              <Button Classes="nav" Content="⚙   设置" Click="Settings_Click" />
            </StackPanel>

            <Border Grid.Row="2" Background="#2F2F2F" Margin="16,0" />
            <TextBlock Grid.Row="3" Text="你的音乐库" Foreground="#B3B3B3" FontWeight="Bold"
                       FontSize="12" Margin="18,16,18,8" />
            <StackPanel Grid.Row="4" Margin="8,0">
              <Button Classes="nav" Content="♥   收藏的歌曲" Click="Favorites_Click" />
              <Button Classes="nav" Content="♫   最近播放" />
            </StackPanel>

            <Button Grid.Row="5" Background="Transparent" BorderThickness="0" Click="Logout_Click"
                    HorizontalContentAlignment="Stretch" Padding="14,8">
              <Grid ColumnDefinitions="36,*" ColumnSpacing="10">
                <Border Width="32" Height="32" CornerRadius="16" Background="#1C6B46">
                  <TextBlock x:Name="AvatarLetter" Text="S" HorizontalAlignment="Center"
                             VerticalAlignment="Center" FontWeight="Bold" />
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                  <TextBlock x:Name="UsernameLabel" Text="Sona" FontWeight="SemiBold" />
                  <TextBlock x:Name="RoleLabel" Text="用户" Foreground="#B3B3B3" FontSize="11" />
                </StackPanel>
              </Grid>
            </Button>
          </Grid>
        </Border>

        <Border Grid.Column="2" Background="#121212" CornerRadius="10">
          <Grid RowDefinitions="72,Auto,*">
            <Grid Grid.Row="0" ColumnDefinitions="*,320" Margin="24,14">
              <TextBlock x:Name="PageTitle" Text="首页" FontSize="30" FontWeight="Bold"
                         VerticalAlignment="Center" />
              <TextBox x:Name="SearchBox" Grid.Column="1" Classes="search"
                       KeyDown="SearchBox_KeyDown" />
            </Grid>

            <Border Grid.Row="1" Background="#242424" CornerRadius="8" Margin="24,0,24,18"
                    Padding="18,14">
              <Grid ColumnDefinitions="*,Auto">
                <StackPanel>
                  <TextBlock Text="欢迎回到 Sona" FontSize="18" FontWeight="Bold" />
                  <TextBlock x:Name="StatusLabel" Text="正在加载你的曲库…" Foreground="#B3B3B3"
                             Margin="0,4,0,0" />
                </StackPanel>
                <Button Grid.Column="1" Content="刷新" Click="Refresh_Click" VerticalAlignment="Center" />
              </Grid>
            </Border>

            <ListBox x:Name="TracksList" Grid.Row="2" Background="Transparent" BorderThickness="0"
                     Margin="16,0,16,8" SelectionMode="Single">
              <ListBox.ItemTemplate>
                <DataTemplate x:DataType="models:Track">
                  <Button Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Stretch"
                          Padding="8,6" Click="Track_Click">
                    <Grid ColumnDefinitions="52,*,150,80" ColumnSpacing="12">
                      <Border Width="48" Height="48" Background="#242424" CornerRadius="5">
                        <TextBlock Text="♪" Foreground="#1ED760" FontSize="21"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                      </Border>
                      <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding Artist}" Foreground="#B3B3B3" FontSize="12"
                                   TextTrimming="CharacterEllipsis" />
                      </StackPanel>
                      <TextBlock Grid.Column="2" Text="{Binding Album}" Foreground="#B3B3B3"
                                 VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                      <TextBlock Grid.Column="3" Text="{Binding DurationText}" Foreground="#B3B3B3"
                                 VerticalAlignment="Center" HorizontalAlignment="Right" />
                    </Grid>
                  </Button>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>

            <Border x:Name="SettingsPanel" Grid.Row="1" Grid.RowSpan="2" Background="#121212"
                    Padding="24" IsVisible="False">
              <StackPanel Spacing="14" MaxWidth="680" HorizontalAlignment="Left">
                <TextBlock Text="连接信息" FontSize="22" FontWeight="Bold" />
                <Border Background="#242424" CornerRadius="10" Padding="18">
                  <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="130,*" RowSpacing="10">
                    <TextBlock Text="服务器" Foreground="#B3B3B3" />
                    <TextBlock x:Name="SettingsServerLabel" Grid.Column="1" TextWrapping="Wrap" />
                    <TextBlock Grid.Row="1" Text="当前账号" Foreground="#B3B3B3" />
                    <TextBlock x:Name="SettingsUserLabel" Grid.Row="1" Grid.Column="1" />
                  </Grid>
                </Border>
                <TextBlock Text="首版 Windows 客户端已支持登录、曲库、搜索、收藏、发现和基础播放。其余管理与社交功能将逐步迁移。"
                           Foreground="#B3B3B3" TextWrapping="Wrap" />
                <Button x:Name="DuplicateManagerButton" Content="歌曲去重" IsVisible="False"
                        HorizontalAlignment="Left" Padding="18,10" Click="OpenDuplicates_Click" />
              </StackPanel>
            </Border>

            <Border x:Name="DuplicatePanel" Grid.Row="1" Grid.RowSpan="2" Background="#121212"
                    Padding="24" IsVisible="False">
              <Grid RowDefinitions="Auto,*" RowSpacing="16">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                  <Button Content="← 返回设置" Click="BackToSettings_Click" />
                  <TextBlock Grid.Column="1" Text="按标准化歌手和歌名列出，不会自动删除。"
                             Foreground="#B3B3B3" VerticalAlignment="Center" />
                  <Button Grid.Column="2" Content="刷新" Click="RefreshDuplicates_Click" />
                </Grid>
                <ScrollViewer Grid.Row="1">
                  <StackPanel>
                    <TextBlock x:Name="DuplicateEmptyLabel" Text="没有重复歌曲"
                               Foreground="#B3B3B3" FontSize="18" Margin="0,24"
                               HorizontalAlignment="Center" IsVisible="False" />
                    <ItemsControl x:Name="DuplicateGroupsList">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:DuplicateTrackGroup">
                          <StackPanel Margin="0,0,0,20" Spacing="8">
                            <TextBlock Text="{Binding Header}" FontSize="18" FontWeight="Bold" />
                            <ItemsControl ItemsSource="{Binding Tracks}">
                              <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:DuplicateTrackItem">
                                  <Border Background="#242424" CornerRadius="10" Padding="14" Margin="0,4">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="14">
                                      <StackPanel Spacing="5">
                                        <TextBlock Text="{Binding VersionText}" FontWeight="SemiBold"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding FileSizeText}" Foreground="#B3B3B3"
                                                   FontSize="12" />
                                        <TextBlock Text="{Binding Path}" Foreground="#8F8F8F" FontSize="11"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="使用中的用户" FontWeight="SemiBold" FontSize="12"
                                                   Margin="0,4,0,0" />
                                        <TextBlock Text="{Binding UsersText}" Foreground="#B3B3B3" FontSize="12"
                                                   TextWrapping="Wrap" />
                                      </StackPanel>
                                      <Button Grid.Column="1" Content="删除" Foreground="#FF6577"
                                              VerticalAlignment="Top" Click="DuplicateDelete_Click" />
                                    </Grid>
                                  </Border>
                                </DataTemplate>
                              </ItemsControl.ItemTemplate>
                            </ItemsControl>
                          </StackPanel>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </ScrollViewer>
              </Grid>
            </Border>
          </Grid>
        </Border>

        <Border Grid.Column="4" Background="#121212" CornerRadius="10">
          <Grid RowDefinitions="64,*">
            <Grid Margin="18,0" ColumnDefinitions="*,Auto">
              <TextBlock Text="播放队列" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" />
              <TextBlock x:Name="QueueCountLabel" Grid.Column="1" Text="0 首"
                         Foreground="#B3B3B3" VerticalAlignment="Center" />
            </Grid>
            <ListBox x:Name="QueueList" Grid.Row="1" Background="Transparent" BorderThickness="0"
                     Margin="8,0,8,8">
              <ListBox.ItemTemplate>
                <DataTemplate x:DataType="models:Track">
                  <StackPanel Margin="8,7">
                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding Artist}" Foreground="#B3B3B3" FontSize="12"
                               TextTrimming="CharacterEllipsis" />
                  </StackPanel>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </Grid>
        </Border>
      </Grid>

      <Grid Grid.Row="1" ColumnDefinitions="1.2*,1.6*,1.2*" Margin="18,0">
        <Grid ColumnDefinitions="60,*" ColumnSpacing="12" VerticalAlignment="Center">
          <Border Width="56" Height="56" Background="#242424" CornerRadius="5">
            <TextBlock Text="♪" Foreground="#1ED760" FontSize="24"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <StackPanel Grid.Column="1" VerticalAlignment="Center">
            <TextBlock x:Name="NowTitle" Text="尚未播放" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
            <TextBlock x:Name="NowArtist" Text="从曲库选择一首歌曲" Foreground="#B3B3B3"
                       FontSize="12" TextTrimming="CharacterEllipsis" />
          </StackPanel>
        </Grid>

        <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
          <StackPanel Orientation="Horizontal" Spacing="16" HorizontalAlignment="Center">
            <Button Classes="icon" Content="⏮" Click="Previous_Click" />
            <Button x:Name="PlayPauseButton" Classes="icon" Background="White" Foreground="Black"
                    Content="▶" Click="PlayPause_Click" />
            <Button Classes="icon" Content="⏭" Click="Next_Click" />
          </StackPanel>
          <Border Width="360" Height="3" Background="#444444" CornerRadius="2" Margin="0,6,0,0" />
        </StackPanel>

        <TextBlock Grid.Column="2" x:Name="QualityLabel" Text="Sona Windows"
                   Foreground="#1ED760" HorizontalAlignment="Right" VerticalAlignment="Center" />
      </Grid>
    </Grid>

    <Border x:Name="LoginPanel" Background="#121212" CornerRadius="16" Width="430"
            Padding="42" HorizontalAlignment="Center" VerticalAlignment="Center">
      <StackPanel Spacing="16">
        <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
          <Border Width="44" Height="44" CornerRadius="22" Background="#1ED760">
            <TextBlock Text="♪" Foreground="#07150B" FontSize="28" FontWeight="Bold"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <TextBlock Text="Sona" FontSize="32" FontWeight="Bold" VerticalAlignment="Center" />
        </StackPanel>
        <TextBlock Text="登录你的私人曲库" Foreground="#B3B3B3" HorizontalAlignment="Center"
                   Margin="0,0,0,10" />
        <TextBlock Text="服务器地址" FontWeight="SemiBold" />
        <TextBox x:Name="ServerBox" Text="http://sosee.eu.cc:6699" PlaceholderText="http://服务器:6699"
                 Padding="12,10" />
        <TextBlock Text="账号" FontWeight="SemiBold" />
        <TextBox x:Name="UsernameBox" PlaceholderText="请输入账号" Padding="12,10" />
        <TextBlock Text="密码" FontWeight="SemiBold" />
        <TextBox x:Name="PasswordBox" PasswordChar="●" PlaceholderText="请输入密码" Padding="12,10"
                 KeyDown="PasswordBox_KeyDown" />
        <TextBlock x:Name="LoginError" Foreground="#FF6577" TextWrapping="Wrap" IsVisible="False" />
        <Button x:Name="LoginButton" Content="登录" Background="#1ED760" Foreground="#07150B"
                FontWeight="Bold" CornerRadius="22" Padding="16,11" Click="Login_Click" />
      </StackPanel>
    </Border>

    <Grid x:Name="DeleteConfirmOverlay" Background="#CC000000" IsVisible="False">
      <Border Width="540" Background="#242424" CornerRadius="16" Padding="26"
              HorizontalAlignment="Center" VerticalAlignment="Center">
        <StackPanel Spacing="14">
          <TextBlock Text="永久删除这首歌曲？" FontSize="22" FontWeight="Bold" />
          <TextBlock Text="此操作不可恢复，将删除服务器音频文件及全部用户引用。"
                     Foreground="#FF6577" TextWrapping="Wrap" />
          <TextBlock x:Name="DeleteConfirmDetails" Foreground="#B3B3B3" TextWrapping="Wrap"
                     MaxHeight="260" />
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
            <Button Content="取消" Click="CancelDuplicateDelete_Click" />
            <Button x:Name="ConfirmDuplicateDeleteButton" Content="永久删除"
                    Background="#E91429" Foreground="White" Click="ConfirmDuplicateDelete_Click" />
          </StackPanel>
        </StackPanel>
      </Border>
    </Grid>
  </Grid>
</Window>
